  "item": [
    {
      "name": "Attractions",
      "item": [
        {
          "name": "Create Attraction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "if (json && json.id) { pm.collectionVariables.set('attractionId', json.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Roller Coaster\",\n  \"description\": \"High-speed ride\",\n  \"capacity\": 20\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/attractions",
              "host": ["{{baseUrl}}"],
              "path": ["attractions"]
            }
          }
        },
        {
          "name": "Get All Attractions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attractions",
              "host": ["{{baseUrl}}"],
              "path": ["attractions"]
            }
          }
        },
        {
          "name": "Get Attraction By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attractions/{{attractionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["attractions", "{{attractionId}}"]
            }
          }
        },
        {
          "name": "Update Attraction",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Roller Coaster XL\",\n  \"description\": \"Updated description\",\n  \"capacity\": 24\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/attractions/{{attractionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["attractions", "{{attractionId}}"]
            }
          }
        },
        {
          "name": "Delete Attraction",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/attractions/{{attractionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["attractions", "{{attractionId}}"]
            }
          }
        }
      ]
