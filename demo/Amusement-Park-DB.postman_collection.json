{
  "info": {
    "name": "Amusement Park DB API",
    "_postman_id": "e318fd97-0569-4c5f-84c6-93058e290501",
    "description": "CRUD по всем сущностям + 5 бизнес-операций",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "attractionId", "value": "1" },
    { "key": "scheduleId", "value": "1" },
    { "key": "maintenanceId", "value": "1" },
    { "key": "visitorId", "value": "1" },
    { "key": "ticketId", "value": "1" }
  ],
  "item": [
    {
      "name": "Attractions CRUD",
      "item": [
        {
          "name": "Create Attraction",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Water Rapids\",\n  \"description\": \"Family water attraction\",\n  \"capacity\": 30\n}"
            },
            "url": "{{baseUrl}}/attractions"
          }
        },
        { "name": "Get All Attractions", "request": { "method": "GET", "url": "{{baseUrl}}/attractions" } },
        { "name": "Get Attraction By Id", "request": { "method": "GET", "url": "{{baseUrl}}/attractions/{{attractionId}}" } },
        {
          "name": "Update Attraction",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Water Rapids Extreme\",\n  \"description\": \"Updated ride profile\",\n  \"capacity\": 28\n}"
            },
            "url": "{{baseUrl}}/attractions/{{attractionId}}"
          }
        },
        { "name": "Delete Attraction", "request": { "method": "DELETE", "url": "{{baseUrl}}/attractions/{{attractionId}}" } }
      ]
    },
    {
      "name": "Schedules CRUD",
      "item": [
        {
          "name": "Create Schedule",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attractionId\": {{attractionId}},\n  \"startTime\": \"2026-03-10T10:00:00\",\n  \"endTime\": \"2026-03-10T10:20:00\"\n}"
            },
            "url": "{{baseUrl}}/schedules"
          }
        },
        { "name": "Get All Schedules", "request": { "method": "GET", "url": "{{baseUrl}}/schedules" } },
        { "name": "Get Schedule By Id", "request": { "method": "GET", "url": "{{baseUrl}}/schedules/{{scheduleId}}" } },
        {
          "name": "Update Schedule",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attractionId\": {{attractionId}},\n  \"startTime\": \"2026-03-10T11:00:00\",\n  \"endTime\": \"2026-03-10T11:20:00\"\n}"
            },
            "url": "{{baseUrl}}/schedules/{{scheduleId}}"
          }
        },
        { "name": "Delete Schedule", "request": { "method": "DELETE", "url": "{{baseUrl}}/schedules/{{scheduleId}}" } }
      ]
    },
    {
      "name": "Maintenances CRUD",
      "item": [
        {
          "name": "Create Maintenance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attractionId\": {{attractionId}},\n  \"startTime\": \"2026-03-12T08:00:00\",\n  \"endTime\": \"2026-03-12T10:00:00\",\n  \"reason\": \"Hydraulics check\"\n}"
            },
            "url": "{{baseUrl}}/maintenances"
          }
        },
        { "name": "Get All Maintenances", "request": { "method": "GET", "url": "{{baseUrl}}/maintenances" } },
        { "name": "Get Maintenance By Id", "request": { "method": "GET", "url": "{{baseUrl}}/maintenances/{{maintenanceId}}" } },
        {
          "name": "Update Maintenance",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attractionId\": {{attractionId}},\n  \"startTime\": \"2026-03-12T09:00:00\",\n  \"endTime\": \"2026-03-12T11:00:00\",\n  \"reason\": \"Updated maintenance plan\"\n}"
            },
            "url": "{{baseUrl}}/maintenances/{{maintenanceId}}"
          }
        },
        { "name": "Delete Maintenance", "request": { "method": "DELETE", "url": "{{baseUrl}}/maintenances/{{maintenanceId}}" } }
      ]
    },
    {
      "name": "Visitors CRUD",
      "item": [
        {
          "name": "Create Visitor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Pavel Romanov\",\n  \"email\": \"pavel.romanov@example.com\"\n}"
            },
            "url": "{{baseUrl}}/visitors"
          }
        },
        { "name": "Get All Visitors", "request": { "method": "GET", "url": "{{baseUrl}}/visitors" } },
        { "name": "Get Visitor By Id", "request": { "method": "GET", "url": "{{baseUrl}}/visitors/{{visitorId}}" } },
        {
          "name": "Update Visitor",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Pavel Romanov Updated\",\n  \"email\": \"pavel.romanov.updated@example.com\"\n}"
            },
            "url": "{{baseUrl}}/visitors/{{visitorId}}"
          }
        },
        { "name": "Delete Visitor", "request": { "method": "DELETE", "url": "{{baseUrl}}/visitors/{{visitorId}}" } }
      ]
    },
    {
      "name": "Tickets CRUD",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visitorId\": {{visitorId}},\n  \"scheduleId\": {{scheduleId}}\n}"
            },
            "url": "{{baseUrl}}/tickets"
          }
        },
        { "name": "Get All Tickets", "request": { "method": "GET", "url": "{{baseUrl}}/tickets" } },
        { "name": "Get Ticket By Id", "request": { "method": "GET", "url": "{{baseUrl}}/tickets/{{ticketId}}" } },
        {
          "name": "Update Ticket",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visitorId\": {{visitorId}},\n  \"scheduleId\": {{scheduleId}}\n}"
            },
            "url": "{{baseUrl}}/tickets/{{ticketId}}"
          }
        },
        { "name": "Delete Ticket", "request": { "method": "DELETE", "url": "{{baseUrl}}/tickets/{{ticketId}}" } }
      ]
    },
    {
      "name": "Business Operations",
      "item": [
        {
          "name": "Bulk Purchase Tickets",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visitorId\": {{visitorId}},\n  \"scheduleIds\": [1, 2]\n}"
            },
            "url": "{{baseUrl}}/operations/tickets/bulk-purchase"
          }
        },
        {
          "name": "Reschedule Ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newScheduleId\": 2\n}"
            },
            "url": "{{baseUrl}}/operations/tickets/{{ticketId}}/reschedule"
          }
        },
        {
          "name": "Plan Maintenance With Conflict Check",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attractionId\": {{attractionId}},\n  \"startTime\": \"2026-03-15T08:00:00\",\n  \"endTime\": \"2026-03-15T09:00:00\",\n  \"reason\": \"Operational diagnostics\"\n}"
            },
            "url": "{{baseUrl}}/operations/maintenances/plan"
          }
        },
        {
          "name": "Deactivate Visitor And Cancel Future Tickets",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/operations/visitors/{{visitorId}}/deactivate"
          }
        },
        {
          "name": "Get Visitor Itinerary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/operations/visitors/{{visitorId}}/itinerary?from=2026-03-01T00:00:00&to=2026-03-31T23:59:59"
          }
        }
      ]
    }
  ]
}
